{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start MongoDB",
            "type": "shell",
            "command": "mongod",
            "args": [
                "--dbpath",
                "C:\\data\\db",
                "--port",
                "27017"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start Development Server",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "dependsOn": "Start MongoDB"
        },
        {
            "label": "Start Production Server",
            "type": "shell",
            "command": "npm",
            "args": ["start"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "dependsOn": "Start MongoDB"
        },
        {
            "label": "Stop MongoDB",
            "type": "shell",
            "command": "taskkill",
            "args": ["/F", "/IM", "mongod.exe"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new"
            }
        }
    ]
}
